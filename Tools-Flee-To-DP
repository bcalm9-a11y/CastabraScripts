--[[ Anti-PK Flee (location-aware, floor-based)
     On a non-friend player: stop hunting, gear up (haste boots + time ring),
     and run to safety —
       in the spawn (floor 8+) -> Walker.Goto("SafeLeave")  (rope out -> depot)
       in town/route (floor 7) -> Walker.Goto("ReachDepot") (straight to depot)
     Pairs with two waypoint guards (see notes under the script). ]]

local FRIENDS = {
    "granada", "santota", "bolx", "eksuro",
    "naks", "jewish hunter", "sneakypocket"
}
local PLAYER_RANGE = 8
local HASTE_BOOTS  = 3079
local TIME_RING    = 3053

FRIENDS = table.lower(FRIENDS)
FLEEING = false      -- GLOBAL: the walker guard lines read this

local function isFriend(name)
    name = string.lower(name)
    for i = 1, #FRIENDS do
        if FRIENDS[i] == name then return true end
    end
    return false
end

local function enemyPlayerNear(range)
    for _, p in ipairs(Creature.iPlayers(range, false)) do
        if p.hpperc > 0 and not isFriend(p.name) then return true end
    end
    return false
end

local function inSpawn()
    return Self.Position().z >= 8      -- spawn is floors 8-11; town/route is floor 7
end

Module.New("Anti-PK Flee", function()
    if not Self.isConnected() or FLEEING then return end
    if not enemyPlayerNear(PLAYER_RANGE) then return end

    FLEEING = true
    PAUSE_MORTHUR = true                       -- stop the hunter (needs the guard in that script)
    Targeting.Enabled(false)                   -- stop the bot's targeting
    Looter.Enabled(false)                      -- stop looting
    Self.EquipItem(SLOT_FEET, HASTE_BOOTS, 1)  -- boots of haste
    Self.EquipItem(SLOT_RING, TIME_RING, 1)    -- time ring
    Walker.Enabled(true)                       -- keep walking...

    if inSpawn() then
        Walker.Goto("SafeLeave")               -- rope out, then forced to depot by the guard
    else
        Walker.Goto("ReachDepot")              -- already in town/route -> depot
    end
    printf("[FLEE] PK detected -> bailing")
end)
