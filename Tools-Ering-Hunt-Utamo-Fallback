--[[ Ring + Shield overlap (no protection gap)
     - Times each ring from equip (RING_DURATION = fresh duration).
     - Casts utamo vita SHIELD_BEFORE seconds before the ring expires, so the
       shield covers the moment the ring is off.
     - Lets the ring run out (consumed -> no bag clutter), then equips a fresh one.
     - Out of rings -> just holds utamo vita until refill. ]]

local RING_ID         = 3051
local RING_DURATION   = 1180            -- seconds a FRESH ring lasts (~20 min, set slightly UNDER true value)
local SHIELD_BEFORE   = 20              -- cast utamo vita this many seconds before the ring expires

local SHIELD_SPELL    = "utamo vita"
local SHIELD_DURATION = 180
local SHIELD_REFRESH  = 160             -- recast cadence when out of rings
local MIN_MANA        = 50

local ringEquipTime = os.clock()
local shieldArmed   = false
local lastShield    = 0

Module.New("Ring + Shield Overlap", function(mod)
    if Self.isConnected() then
        local slot = Self.Ring().id

        if slot > 0 then
            -- ring worn -> cast the shield once, shortly before it expires
            if not shieldArmed
            and os.clock() - ringEquipTime >= (RING_DURATION - SHIELD_BEFORE)
            and Self.Mana() >= MIN_MANA then
                Self.Say(SHIELD_SPELL)
                shieldArmed = true
                lastShield  = os.time()
            end
        else
            -- ring expired (slot empty)
            if Self.ItemCount(RING_ID) > 0 then
                Self.EquipItem(SLOT_RING, RING_ID, 1)    -- fresh ring on
                ringEquipTime = os.clock()
                shieldArmed   = false                     -- start the next cycle
            elseif Self.Mana() >= MIN_MANA
            and os.time() - lastShield > SHIELD_REFRESH then
                Self.Say(SHIELD_SPELL)                    -- out of rings -> hold the shield
                lastShield = os.time()
            end
        end
    end
    mod:Delay(100)    -- fast: the ring-off gap is ~0.1s, fully under the shield
end)
