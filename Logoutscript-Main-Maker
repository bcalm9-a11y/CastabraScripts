--[[ NIGEL (level 85) -- relay hub
     
self-panic only when ATTACKED (HP drops)
relays Kazey/Jessesgotagun HELP and their deaths (channel 25) to Game-Chat (17)
one panic per event (alert_cooldown)
Casey says "buu" in default chat (0): log out 10s then relog ]]
local config = {
    gamechat_id    = 17,
    panic_text     = "BRING ME TO THAIS",
    low_blockers   = {"Kazey", "Jessesgotagun"},
    help_keyword   = "help",
    death_channel  = 25,
    passer         = "Casey",
    buu_word       = "buu",
    buu_channel    = 0,
    relogin_after  = 10,
    alert_cooldown = 30,
    debug          = true
}
config.low_blockers = table.lower(config.lowblockers)
local panicTime, relog, logTime = 0, false, 0
local lastHp = -1

local function isLowBlocker(spk)
    for , n in ipairs(config.low_blockers) do
        if spk == n then return true end
    end
    return false
end
local function sendPanic(reason)
    if os.clock() - panicTime > config.alert_cooldown then
        Self.SayOnChannel(config.panic_text, config.gamechatid)
        panicTime = os.clock()
        printf("[NIGEL] panic -> Game-Chat (" .. reason .. ")")
    end
end

function nigelProxy(messages)
    for , msg in ipairs(messages) do
        if config.debug then
            printf("[NIGEL] ch=" .. tostring(msg.channel) .. " from '" .. tostring(msg.speaker) .. "': '" .. tostring(msg.message) .. "'")
        end
        local spk = string.lower(tostring(msg.speaker))
        local txt = string.lower(tostring(msg.message))

        -- buu passthrough from Casey (default chat)
        if msg.channel == config.buu_channel and spk == string.lower(config.passer)
        and txt == config.buu_word then
            relog = true
            printf("[NIGEL] buu -> logging out for passthrough")
            return
        end
        -- HELP from a level 8 (local say or PM)
        if isLowBlocker(spk) and string.find(txt, config.help_keyword, 1, true) then
            sendPanic("HELP from " .. spk)
            return
        end
        -- a level 8 in the deaths channel
        if msg.channel == config.deathchannel then
            for , n in ipairs(config.low_blockers) do
                if string.find(txt, n, 1, true) or string.find(spk, n, 1, true) then
                    sendPanic("death " .. n)
                    return
                end
            end
        end
    end
end
Proxy.New("nigelProxy")

Module.New("Nigel Relay + Buu Relog", function()
    -- buu logout / relog state machine
    if relog then
        if Self.isConnected() then
            if logTime == 0 then
                Self.Logout()
            else
                relog, logTime = false, 0
                printf("[NIGEL] back online after buu")
            end
        else
            if logTime == 0 then
                logTime = os.clock()
                printf("[NIGEL] logged out; relog in " .. config.relogin_after .. "s")
            elseif os.clock() - logTime > config.relogin_after then
                Rifbot.PressKey(13, 2000)
            end
        end
        wait(200)
        return
    end

    -- self-panic only when taking damage
    if Self.isConnected() then
        local hp = Self.HealthPercent()
        if lastHp < 0 then lastHp = hp end
        if hp < lastHp then sendPanic("Nigel attacked") end
        lastHp = hp
    end
    wait(200)
end)
